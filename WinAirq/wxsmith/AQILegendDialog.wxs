<?xml version="1.0" encoding="utf-8" ?>
<wxsmith>
	<object class="wxDialog" name="AQILegendDialog">
		<title>Air quality index - Legend</title>
		<id_arg>0</id_arg>
		<handler function="OnKeyDown" entry="EVT_KEY_DOWN" />
		<object class="wxFlexGridSizer" variable="FgsMain" member="no">
			<cols>1</cols>
			<rows>2</rows>
			<object class="sizeritem">
				<object class="wxPanel" name="ID_PNLHEADER" variable="PnlHeader" member="yes">
					<bg>wxSYS_COLOUR_WINDOW</bg>
					<style>wxSUNKEN_BORDER|wxTAB_TRAVERSAL</style>
					<handler function="OnKeyDown" entry="EVT_KEY_DOWN" />
					<object class="wxFlexGridSizer" variable="FgsHeader" member="no">
						<cols>2</cols>
						<rows>1</rows>
						<object class="sizeritem">
							<object class="wxStaticText" name="ID_LBLQUALITATIVENAME" variable="LblQualitativeName" member="yes">
								<label>Qualitative name</label>
								<font>
									<weight>bold</weight>
								</font>
								<minsize>130,-1</minsize>
								<maxsize>130,-1</maxsize>
							</object>
							<flag>wxALL|wxEXPAND|wxALIGN_CENTER_HORIZONTAL|wxALIGN_CENTER_VERTICAL</flag>
							<border>5</border>
							<option>1</option>
						</object>
						<object class="sizeritem">
							<object class="wxFlexGridSizer" variable="FgsPollutantConcentration" member="no">
