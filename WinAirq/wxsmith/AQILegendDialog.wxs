										<font>
											<weight>bold</weight>
										</font>
									</object>
									<flag>wxTOP|wxBOTTOM|wxLEFT|wxALIGN_CENTER_HORIZONTAL|wxALIGN_CENTER_VERTICAL</flag>
									<border>5</border>
									<option>1</option>
								</object>
								<object class="sizeritem">
									<object class="wxStaticText" name="ID_LBLPOLLUTANTCONCENTRATION_2" variable="LblPollutantConcentration_2" member="yes">
										<label>3</label>
