				</Compiler>
				<ResourceCompiler>
					<Add directory="E:/wxWidgets-2.8.12/lib/gcc_lib/mswud" />
				</ResourceCompiler>
				<Linker>
					<Add library="libwxmsw28ud.a" />
					<Add library="libwxpngd.a" />
					<Add library="libwxjpegd.a" />
					<Add library="libwxtiffd.a" />
					<Add library="libwxzlibd.a" />
					<Add directory="E:/wxWidgets-2.8.12/lib/gcc_lib" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/winairq" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="0" />
				<Option compiler="gcc" />
				<Option projectLinkerOptionsRelation="2" />
				<Compiler>
					<Add option="-O2" />
					<Add directory="E:/wxWidgets-2.8.12/lib/gcc_lib/mswu" />
					<Add directory="include" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="E:/wxWidgets-2.8.12/lib/gcc_lib/mswu" />
				</ResourceCompiler>
				<Linker>
					<Add option="-s" />
					<Add library="libwxmsw28u.a" />
					<Add library="libwxpng.a" />
					<Add library="libwxjpeg.a" />
					<Add library="libwxtiff.a" />
					<Add library="libwxzlib.a" />
					<Add directory="E:/wxWidgets-2.8.12/lib/gcc_lib" />
				</Linker>
				<ExtraCommands>
					<Add after='E:\Moje programy\upx\upx &quot;$(PROJECTDIR)$(TARGET_OUTPUT_DIR)winairq.exe&quot;' />
				</ExtraCommands>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
			<Add option="-pipe" />
			<Add option="-mthreads" />
			<Add option='[[if (GetCompilerFactory().GetCompilerVersionString(_T(&quot;gcc&quot;)) &gt;= _T(&quot;4.8.0&quot;)) print(_T(&quot;-Wno-unused-local-typedefs&quot;));]]' />
			<Add option="-D__GNUWIN32__" />
			<Add option="-D__WXMSW__" />
			<Add option="-DwxUSE_UNICODE" />
			<Add option="-DwxUSE_UNICODE_MSLU" />
			<Add directory="E:/wxWidgets-2.8.12/include" />
		</Compiler>
		<ResourceCompiler>
			<Add directory="E:/wxWidgets-2.8.12/include" />
		</ResourceCompiler>
		<Linker>
			<Add option="--enable-mslu" />
			<Add option="-mthreads" />
			<Add library="lib\libunicows.a" />
			<Add library="libkernel32.a" />
			<Add library="libuser32.a" />
			<Add library="libgdi32.a" />
			<Add library="libwinspool.a" />
